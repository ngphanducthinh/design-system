{
  "include": ["env.d.ts", "src/**/*"],
  "exclude": ["src/App.vue", "src/main.ts", "src/stories", ".storybook/**/*"],
  "compilerOptions": {
    "target": "ES2022",
    "allowImportingTsExtensions": true,
    "module": "ES2022",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
