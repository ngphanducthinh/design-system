{
  "name": "@7pmlabs/design-system",
  "version": "1.0.0-beta.0",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/ngphanducthinh/design-system",
  "scripts": {
    "dev": "vite",
    "build": "run-s lint-all build:lib",
    "build:lib": "vite build && npm run build:types",
    "build:types": "vue-tsc --project tsconfig.types.json --declaration --emitDeclarationOnly --outDir dist/types",
    "lint-all": "run-p lint type-check",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "preview": "vite preview",
    "test:unit": "vitest --project unit",
    "test:storybook": "vitest --project storybook",
    "test:all": "vitest",
    "test:e2e": "playwright test",
    "build-only": "vite build",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore --allow no-shadow-restricted-names",
    "lint:eslint": "eslint . --fix",
    "lint": "run-s lint:*",
    "format": "prettier --write src/",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:int": "bun run scripts/test-integration.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/addon-onboarding": "^10.4.0",
    "@storybook/addon-themes": "^10.4.0",
    "@storybook/addon-vitest": "^10.4.0",
    "@storybook/vue3-vite": "^10.4.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^21.1.7",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.12.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/eslint-plugin": "^1.6.17",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.39.4",
    "eslint-plugin-oxlint": "^1.65.0",
    "eslint-plugin-playwright": "^2.10.2",
    "eslint-plugin-storybook": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "jiti": "^2.7.0",
    "jsdom": "^26.1.0",
    "lodash-es": "^4.18.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.65.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "storybook": "^10.4.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "8.0.0",
    "vite-plugin-static-copy": "^3.4.0",
    "vite-plugin-vue-devtools": "^7.7.9",
    "vitest": "^3.2.4",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4",
    "vue-tsc": "^3.2.9",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "vue": "^3.5.22",
    "vue-router": "^4.6.0",
    "zod": "^3.25.0"
  },
  "peerDependenciesMeta": {
    "vue-router": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ],
  "main": "./dist/design-system.js",
  "module": "./dist/design-system.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/design-system.js",
      "types": "./dist/types/index.d.ts"
    },
    "./style.css": {
      "import": "./dist/design-system.css",
      "require": "./dist/design-system.css"
    }
  },
  "sideEffects": [
    "dist/design-system.css",
    "dist/**/*.css"
  ],
  "keywords": [
    "vue",
    "ui library",
    "design system"
  ]
}